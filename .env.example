# Server Configuration
PORT=10000
NODE_ENV=production

# Frontend URL Configuration (Flexible - Choose one method)
# Method 1: Single frontend URL
FRONTEND_URL=https://your-frontend-url.com

# Method 2: Multiple frontend URLs (comma-separated)
CORS_ORIGIN=https://your-frontend-url.com,https://another-frontend.com,http://localhost:3000

# Method 3: Development (allows all origins)
# NODE_ENV=development

# Database Configuration (Render.com provides DATABASE_URL)
DATABASE_URL=postgresql://username:password@host:port/database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mathquest
DB_USER=postgres
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Redis Configuration (Render.com provides REDIS_URL)
REDIS_URL=redis://host:port
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
